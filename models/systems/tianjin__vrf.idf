  EnergyManagementSystem:Program,
    DOAS_HX_LowFlowLockout,
    IF DOAS_HX_SupplyMassFlow >= 2.020,
    SET DOAS_HX_AvailabilityActuator = 1,
    ELSE,
    SET DOAS_HX_AvailabilityActuator = 0,
    ENDIF;

